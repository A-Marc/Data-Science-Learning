import numpy as np


arr= np.array([10,20 , 30 ,40 , 50])
print(arr[0])
# print(arr[10])
print(arr[0:9])
print(arr[9:11])
print(arr[3:5:7])
print(arr[::-1])



arr=np.array([[2,3,4,5],[3,4,5,6]])
print(arr)

print(arr[0,2])
print(arr[0:2,1:3]) # rows:coluns


# not same as python list and copy

arr=np.array([2,3,4,5])
sliced=arr[1:5]
print(arr.shape)
print(arr)
print(sliced)

sliced[0]=9999999
print("arr:",arr)
print("sli:",sliced)



# we have to use , copy()

arr=np.array([2,3,4,5])
sliced=arr[1:5].copy()
print(arr)
print(sliced)

sliced[0]=9999999
print("arr:",arr)
print("sli:",sliced)


# fancy indexing

arr=np.array([2,3,4,5])
index=[1,3]
print(arr[index])

arr2=np.array([[2,3,4,5],[3,4,5,6]])
print(arr2[[0,1],[1,2]])


